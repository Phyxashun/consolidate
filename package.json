{
    "name": "consolidate",
    "version": "2.5.0",
    "description": "A utility script to consolidate project files into single, combined output files. Also provides deconsolidate to rebuild the project files.",
    "main": "./src/index.ts",
    "module": "index.ts",
    "type": "module",
    "scripts": {
        "typecheck": "tsc --noEmit",
        "build": "bun run typecheck && bun build --compile --outfile=./dist/consolidate ./src/index.ts",
        "start": "bun run ./src/index.ts",
        "consolidate": "bun run ./src/consolidate.ts",
        "deconsolidate": "bun run ./src/deconsolidate.ts",
        "push": "bun run ./src/push.ts"
    },
    "bin": {
        "consolidate": "./src/index.ts"
    },
    "keywords": [
        "consolidate",
        "deconsolidate",
        "merge",
        "project",
        "rebuild"
    ],
    "author": "Dustin Dew",
    "license": "MIT",
    "dependencies": {
        "typescript": "latest",
        "@clack/prompts": "latest",
        "@pdf-lib/fontkit": "latest",
        "bun": "latest",
        "glob": "latest",
        "pdf-lib": "latest",
        "picocolors": "latest"
    },
    "devDependencies": {
        "@types/glob": "latest",
        "prettier": "latest",
        "@eslint/js": "latest",
        "@types/bun": "latest",
        "@types/node": "latest",
        "@typescript-eslint/parser": "latest",
        "eslint": "latest",
        "eslint-config-prettier": "latest",
        "eslint-plugin-eslint-plugin": "latest",
        "eslint-plugin-prettier": "latest",
        "globals": "latest",
        "jiti": "latest",
        "typescript-eslint": "latest"
    }
}