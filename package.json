{
  "name": "consolidate",
  "version": "2.5.0",
  "description": "A utility script to consolidate project files into single, combined output files. Also provides deconsolidate to rebuild the project files.",
  "main": "index.ts",
  "module": "index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "bun run ./index.ts",
    "consolidate": "bun run ./src/consolidate.ts",
    "deconsolidate": "bun run ./src/deconsolidate.ts"
  },
  "bin": {
    "consolidate": "./index.ts"
  },
  "keywords": [
    "consolidate",
    "deconsolidate",
    "merge",
    "project",
    "rebuild"
  ],
  "author": "Dustin Dew",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "bun": "^1.3.14",
    "picocolors": "^1.1.1",
    "glob": "latest"
  },
  "devDependencies": {
    "@types/glob": "latest",
    "prettier": "latest",
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-plugin": "^7.4.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}