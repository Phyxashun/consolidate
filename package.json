{
    "name": "consolidate",
    "version": "2.0.0",
    "description": "A utility script to consolidate project files into single, combined output files.",
    "main": "consolidate.ts",
    "module": "consolidate.ts",
    "type": "module",
    "scripts": {
        "start": "bun run ./consolidate.ts"
    },
    "bin": {
        "consolidate": "./index.ts"
    },
    "keywords": [
        "consolidate",
        "merge",
        "project"
    ],
    "author": "Dustin Dew",
    "license": "MIT",
    "dependencies": {
        "figlet": "latest",
        "glob": "latest"
    },
    "peerDependencies": {
        "typescript": "latest"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/figlet": "latest",
        "@types/glob": "latest",
        "@types/node": "latest",
        "prettier": "latest"
    }
}
