{
    "name": "consolidate",
    "version": "2.0.0",
    "description": "A utility script to consolidate project files into single, combined output files. Also provides deconsolidate to rebuild the project files.",
    "main": "index.ts",
    "module": "index.ts",
    "type": "module",
    "scripts": {
        "start": "bun run ./index.ts"
    },
    "bin": {
        "consolidate": "./index.ts"
    },
    "keywords": [
        "consolidate",
        "deconsolidate",
        "merge",
        "project",
        "rebuild"
    ],
    "author": "Dustin Dew",
    "license": "MIT",
    "dependencies": {
        "figlet": "latest",
        "glob": "latest",
        "node": "latest"
    },
    "peerDependencies": {
        "typescript": "latest"
    },
    "devDependencies": {
        "@types/bun": "^1.3.11",
        "@types/figlet": "latest",
        "@types/glob": "latest",
        "@types/node": "^25.5.0",
        "prettier": "latest"
    }
}
